// api/claude-bridge.js
// Deploy this to Vercel as a serverless function

export default async function handler(req, res) {
  // Allow requests from anywhere (needed for Roblox HttpService proxy)
  res.setHeader("Access-Control-Allow-Origin", "*");
  res.setHeader("Access-Control-Allow-Methods", "POST, OPTIONS");
  res.setHeader("Access-Control-Allow-Headers", "Content-Type, x-api-key");

  if (req.method === "OPTIONS") return res.status(200).end();
  if (req.method !== "POST") return res.status(405).json({ error: "Method not allowed" });

  // Simple auth check using a secret you set in Vercel env vars
  const clientKey = req.headers["x-api-key"];
  if (clientKey !== process.env.CLIENT_SECRET) {
    return res.status(401).json({ error: "Unauthorized" });
  }

  const { action, data } = req.body;

  if (!action || !data) {
    return res.status(400).json({ error: "Missing action or data" });
  }

  // Build the prompt based on what the executor sends
  let prompt = "";

  if (action === "spawn_pet") {
    prompt = `
You are a Roblox Lua script generator. The user wants to spawn a pet visual in their game.
Game data from Dex Explorer:
${JSON.stringify(data, null, 2)}

Generate a complete, working Roblox Lua script that:
1. Creates a pet visual (BillboardGui above player head OR a small floating part)
2. Uses the player/character info from the game data above
3. Is safe to run in an executor (client-side)
4. Includes a simple animation (bobbing up and down)

Return ONLY the Lua code, no explanation.
    `.trim();
  } else if (action === "analyze") {
    prompt = `
You are a Roblox game analyzer. Here is data from the Dex Explorer:
${JSON.stringify(data, null, 2)}

Analyze this and tell me:
1. What scripts are present
2. Any interesting instances
3. Suggestions for what can be exploited or modified

Be concise and clear.
    `.trim();
  } else {
    prompt = `
You are a Roblox Lua assistant. Here is game data:
${JSON.stringify(data, null, 2)}

User request: ${action}

Respond helpfully.
    `.trim();
  }

  try {
    const response = await fetch("https://api.anthropic.com/v1/messages", {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
        "x-api-key": process.env.ANTHROPIC_API_KEY,
        "anthropic-version": "2023-06-01"
      },
      body: JSON.stringify({
        model: "claude-sonnet-4-6",
        max_tokens: 1000,
        messages: [{ role: "user", content: prompt }]
      })
    });

    const result = await response.json();
    const text = result.content?.[0]?.text || "No response";

    return res.status(200).json({ response: text });
  } catch (err) {
    console.error(err);
    return res.status(500).json({ error: "Claude API call failed" });
  }
}

