export default async function handler(req, res) {
  res.setHeader("Access-Control-Allow-Origin", "*");
  res.setHeader("Access-Control-Allow-Methods", "POST, OPTIONS");
  res.setHeader("Access-Control-Allow-Headers", "Content-Type, x-api-key");

  if (req.method === "OPTIONS") return res.status(200).end();
  if (req.method !== "POST") return res.status(405).json({ error: "Method not allowed" });

  const clientKey = req.headers["x-api-key"];
  if (clientKey !== process.env.CLIENT_SECRET) {
    return res.status(401).json({ error: "Unauthorized" });
  }

  const { action, data } = req.body;
  if (!action || !data) {
    return res.status(400).json({ error: "Missing action or data" });
  }

  let prompt = "";

  if (action === "spawn_pet") {
    prompt = `You are a Roblox Lua script generator. The user wants to spawn a pet visual in their game.
Game data from Dex Explorer:
${JSON.stringify(data, null, 2)}

Generate a complete, working Roblox Lua script that:
1. Creates a cute pet visual that floats above the player's head using a BillboardGui
2. Uses the player/character info from the game data above
3. Is safe to run in an executor (client-side only)
4. Includes a simple bobbing animation
5. Shows a pet emoji or icon

Return ONLY the Lua code, no explanation, no markdown, no backticks.`.trim();
  } else if (action === "analyze") {
    prompt = `You are a Roblox game analyzer. Here is data from Dex Explorer:
${JSON.stringify(data, null, 2)}
Analyze this and tell me what scripts are present and anything interesting. Be concise.`.trim();
  } else {
    prompt = `You are a Roblox Lua assistant. Game data: ${JSON.stringify(data, null, 2)}
User request: ${action}
Respond with only Lua code, no explanation.`.trim();
  }

  try {
    const geminiUrl = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent?key=${process.env.GEMINI_API_KEY}`;

    const response = await fetch(geminiUrl, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        contents: [{ parts: [{ text: prompt }] }],
        generationConfig: { maxOutputTokens: 1000 }
      })
    });

    const result = await response.json();

    if (result.error) {
      return res.status(500).json({ error: result.error.message });
    }

    const text = result.candidates?.[0]?.content?.parts?.[0]?.text || "No response";
    const clean = text.replace(/```lua\n?/g, "").replace(/```\n?/g, "").trim();

    return res.status(200).json({ response: clean });
  } catch (err) {
    return res.status(500).json({ error: "Gemini API call failed: " + err.message });
  }
}
